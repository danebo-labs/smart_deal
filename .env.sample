# ==============================================================================
# Smart Deal — local environment (.env)
# ==============================================================================
#
# Setup:
#   cp .env.sample .env
#   Fill DEV AWS IDs only (see docs/ENVIRONMENTS.md when available, or Fase 0a
#   runbook in the roadmap plan). Never paste production IDs here.
#
# Priority: ENV vars (this file) override Rails encrypted credentials.
# Production uses config/deploy.yml + .kamal/secrets (no .env on the server).
# Credentials fallback: config/credentials.example.yml
#
# ==============================================================================

# --- AWS credentials (required for Bedrock & S3 in local dev) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Optional bearer auth instead of access key pair:
# AWS_BEDROCK_BEARER_TOKEN=

# --- AWS dev isolation (Fase 0a) — DEV ONLY ---
# Create resources in us-east-1 (runbook: docs/ENVIRONMENTS.md §2).
# Production IDs belong in config/deploy.yml / .kamal/secrets only.
#
# Do not paste production IDs here. Production uses config/deploy.yml.
KNOWLEDGE_BASE_S3_BUCKET=smart-deal-dev-kb
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_BULK_DATA_SOURCE_ID=
# Legacy Bedrock FM-parse data source. Current web/bulk uploads use
# BEDROCK_BULK_DATA_SOURCE_ID instead.
# BEDROCK_DATA_SOURCE_ID=

# Emergency override if AwsEnvironmentGuard blocks boot (dev only; never default):
# ALLOW_PROD_AWS=true

# Guard metadata for production deploy, if you enable local environment guards:
# PRODUCTION_KB_ID=
# PRODUCTION_S3_BUCKET=
# PRODUCTION_BULK_DATA_SOURCE_ID=

# --- Bedrock models ---
# us. profile: ~20% cheaper than global., same model (us-east-1 routing).
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Chat image attachments (Haiku cannot read images).
BEDROCK_VISION_MODEL_ID=global.anthropic.claude-sonnet-4-6
# UI reference — must match KB embedding model (Titan Text v2, 1024-dim).
# BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Optional RAG retrieve_and_generate overrides (defaults in BedrockRagService):
# BEDROCK_RAG_NUMBER_OF_RESULTS=10
# BEDROCK_RAG_SEARCH_TYPE=HYBRID
# BEDROCK_RAG_GENERATION_TEMPERATURE=0.3
# BEDROCK_RAG_GENERATION_MAX_TOKENS=3000
# BEDROCK_RERANKER_ENABLED=false

AI_PROVIDER=bedrock

# --- Anthropic API ---
# Required for /bulk_uploads (web + bulk ZIP chunking via Anthropic Messages API).
# Without it, AnthropicTokenCounter uses a local heuristic for chat metrics only.
ANTHROPIC_API_KEY=


# --- Query routing (dormant on web — RAG-only MVP) ---
# QUERY_ROUTING_ENABLED=false

# --- PostgreSQL (app + Solid Cache/Queue/Cable) ---
# DB_HOST=localhost
# DB_USERNAME=app_user
DB_PASSWORD=

# --- Client business DB (Text-to-SQL lane; dormant unless QUERY_ROUTING_ENABLED) ---
# CLIENT_DB_HOST=localhost
# CLIENT_DB_PORT=5432
# CLIENT_DB_NAME=app_db
# CLIENT_DB_USERNAME=app_user
CLIENT_DB_PASSWORD=

# --- Mission Control (/jobs — Solid Queue UI) ---
# Dev defaults: user/password "dev" if unset (mission_control_jobs.rb).
# MISSION_CONTROL_JOBS_USER=dev
# MISSION_CONTROL_JOBS_PASSWORD=dev

# --- MVP shared web session (README § Configuration flags) ---
# SHARED_SESSION_ENABLED=true
# SHARED_SESSION_IDENTIFIER=mvp-shared
# SHARED_SESSION_CHANNEL=shared
# SESSION_MAX_ENTITIES=10

# --- Solid Queue / Puma (local) ---
# SOLID_QUEUE_IN_PUMA=1
# RAILS_MAX_THREADS=3
# PORT=3000

# --- Production worker tuning (deploy.yml — not dev defaults) ---
# RAILS_MAX_THREADS=8
# AWS_HTTP_OPEN_TIMEOUT=5
# AWS_HTTP_READ_TIMEOUT=90
# AWS_HTTP_IDLE_TIMEOUT=5
INGESTION_REENQUEUE=true

# --- AppSignal (production monitoring; inactive outside production) ---
# Put the production key in .kamal/secrets or credentials, not in committed files.
# APPSIGNAL_PUSH_API_KEY=

# --- Aurora cluster id (optional dashboard metrics) ---
# AURORA_DB_CLUSTER_IDENTIFIER=

# --- WhatsApp / Twilio (dormant — webhook not mounted) ---
# See docs/WHATSAPP.md. Only needed to reactivate the channel.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# WA_FACETED_OUTPUT_ENABLED=true
# WA_PROCESSING_ACK_ENABLED=true
