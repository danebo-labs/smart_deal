# ==============================================================================
# Smart Deal - Environment Variables
# ==============================================================================
#
# SETUP:
#   1. Copy this file:  cp .env.sample .env
#   2. Fill in the values below
#   3. The .env file is loaded automatically in development/test (via dotenv-rails)
#   4. NEVER commit .env to git (it's already in .gitignore)
#
# NOTE: ENV vars (this file) take priority over Rails Encrypted Credentials.
# In production (where .env doesn't exist), credentials.yml.enc is used as fallback.
# See: config/credentials.example.yml for the credentials structure.
#
# ==============================================================================

# --- Anthropic API (for count_tokens: exact query tokenization) ---
# Used ONLY for token counting (free, no model invocation).
# If blank, AnthropicTokenCounter uses a local heuristic (chars/3.5, ±5%).
# In production, add it to config/credentials.yml.enc under anthropic: api_key:
#   bin/rails credentials:edit
#   anthropic:
#     api_key: sk-ant-api...
ANTHROPIC_API_KEY=

# --- AWS Configuration (required for Bedrock & S3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- AWS Bedrock Bearer Token (alternative auth, optional) ---
# Use this if you have a bearer token instead of access key/secret key
# AWS_BEDROCK_BEARER_TOKEN=

# --- Bedrock Models & Knowledge Base ---
# Pilot KB: VBB72VKABV / data source OWRPGSX6XK (no inclusion prefix; indexes the whole bucket)
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_DATA_SOURCE_ID=

# Primary model for RAG response generation
# Options: haiku (cheap), sonnet (balance), opus (max quality)
# Global profiles recommended for production (better throughput, same price)
BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0

# Model for multimodal queries (with images)
BEDROCK_VISION_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# Embedding model (configured in AWS Knowledge Base, reference only)
# Current KB uses amazon.nova-2-multimodal-embeddings-v1:0 (1024 dimensions).
# BEDROCK_EMBEDDING_MODEL_ID=amazon.nova-2-multimodal-embeddings-v1:0

# Alternative models for testing/comparison:
# Haiku 4.5 (most economical): us.anthropic.claude-haiku-4-5-20251001-v1:0
# Sonnet 4.5 (recommended): us.anthropic.claude-sonnet-4-5-20250929-v1:0 or global.anthropic.claude-sonnet-4-5-20250929-v1:0
# Opus 4.5 (max quality): us.anthropic.claude-opus-4-5-20251101-v1:0
# Claude 3.7: anthropic.claude-3-7-sonnet-20250219-v1:0

# --- S3 Knowledge Base Bucket ---
# KB data source bucket (current pilot: multimodal-source-destination)
KNOWLEDGE_BASE_S3_BUCKET=

# --- AI Provider (default: bedrock) ---
AI_PROVIDER=bedrock

# --- AppSignal Monitoring (optional for local dev) ---
# APPSIGNAL_PUSH_API_KEY=

# --- Aurora DB (optional, for metrics) ---
# AURORA_DB_CLUSTER_IDENTIFIER=

# --- Mission Control (Solid Queue UI at /jobs) ---
# Development defaults to user/password dev if unset (see config/initializers/mission_control_jobs.rb).
# MISSION_CONTROL_JOBS_USER=dev
# MISSION_CONTROL_JOBS_PASSWORD=dev

# --- Rails Configuration ---
# RAILS_MASTER_KEY=           # Only needed if config/master.key doesn't exist
# RAILS_MAX_THREADS=3
# PORT=3000
# SOLID_QUEUE_IN_PUMA=1      # Run Solid Queue supervisor inside Puma (optional)

# --- Production sizing (recommended floors) ---------------------------------
# These are PRODUCTION floors, not dev defaults. Database pool auto-scales to
# RAILS_MAX_THREADS + 2 (see config/database.yml).
#
# Pool floor: must cover Puma threads + Solid Queue lanes (default=4 + ingestion=1)
# concurrently hitting the pool. With RAILS_MAX_THREADS=8, AR pool=10 covers
# 5 Puma + 4 default-lane + 1 ingestion-lane peak without ConnectionTimeoutError.
# RAILS_MAX_THREADS=8
#
# AWS SDK HTTP timeouts (seconds). Read timeout must comfortably cover Aurora
# Serverless cold-start (~60s) + Bedrock generation. Open + idle short to fail
# fast on dead endpoints.
# AWS_HTTP_OPEN_TIMEOUT=5
# AWS_HTTP_READ_TIMEOUT=90
# AWS_HTTP_IDLE_TIMEOUT=5
#
# BedrockIngestionJob execution mode. Default (false) keeps the legacy blocking
# loop. Set to true ONLY after draining the Solid Queue (otherwise serialized
# legacy jobs keep blocking until terminal). Re-enqueue mode frees the worker
# thread between polls so concurrent uploads + tracking jobs share the lane.
INGESTION_REENQUEUE=true

# --- Shared Session (MVP: all technicians share one conversation context) ---
# SHARED_SESSION_ENABLED=true   # MVP single thread; omit or "false" to isolate by number/user
# SHARED_SESSION_IDENTIFIER=mvp-shared
# SHARED_SESSION_CHANNEL=shared
# SESSION_MAX_ENTITIES=10       # Caps active_entities + preload count on new session (default 10)

# --- R3 WhatsApp: structured (dynamic-section) cache + follow-up classifier ---
# WA_FACETED_OUTPUT_ENABLED=true   # false → roll back to perform_legacy (no R3 cache)
# WA_PROCESSING_ACK_ENABLED=true   # Processing ack before every full RAG call (:new_query and perform_legacy).
#                                    # No ack on section_hit, menu redraw, reset, or post-reset (text only).
#
# NOTES:
# - WA_NANO_CLASSIFIER_ENABLED was removed (safety-policy refactor: closed
#   allowlist for nav tokens; free text always goes to RAG). Remove the line
#   from your .env if present — it is no longer read.
# - R3 replaced the fixed 4-facet schema with dynamic sections + pinned
#   risks. Cache key bumped to v4; old v3 payloads are auto-purged on read.

