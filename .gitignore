# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# macOS system files
.DS_Store
**/.DS_Store

# Ignore bundler config.
/.bundle

# Ignore all environment files (but keep the sample template).
/.env*
!/.env.sample

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Ignore Cline rules (local development configuration)
.clinerules/

# Ignore personal meeting notes
meeting*.txt

/app/assets/builds/*
!/app/assets/builds/.keep

# Local Next.js UI export snapshots + export helper (generated; do not commit)
/b_50FI0lfi5Ny/
/b_I0BM7kf3sAV/
/bin/export_ui_for_ai
/test/bin/export_ui_for_ai_test.rb
