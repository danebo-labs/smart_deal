<%= render layout: "devise/shared/auth_form_shell",
           locals: {
             title: "Crear cuenta",
             subtitle: "Solicita acceso con tu correo corporativo."
           } do %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
               html: { class: "space-y-5" }) do |f| %>

    <div class="space-y-1.5">
      <%= f.label :email, "Correo electrónico",
          class: "block text-sm font-medium text-[hsl(222,47%,10%)]" %>
      <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          placeholder: "tu@empresa.com",
          class: "h-11 w-full rounded-lg border border-[hsl(215,20%,88%)] bg-white px-3 text-sm text-[hsl(222,47%,10%)] placeholder-[hsl(215,20%,65%)] transition focus:border-[hsl(217,91%,50%)] focus:outline-none focus:ring-2 focus:ring-[hsl(217,91%,50%)]/30" %>
    </div>

    <div class="space-y-1.5">
      <%= f.label :password, "Contraseña",
          class: "block text-sm font-medium text-[hsl(222,47%,10%)]" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-[hsl(215,20%,52%)]">Mínimo <%= @minimum_password_length %> caracteres</p>
      <% end %>
      <%= password_field_with_toggle f, :password,
          autocomplete: "new-password",
          placeholder: "••••••••",
          class: "h-11 w-full rounded-lg border border-[hsl(215,20%,88%)] bg-white text-sm text-[hsl(222,47%,10%)] placeholder-[hsl(215,20%,65%)] transition focus:border-[hsl(217,91%,50%)] focus:outline-none focus:ring-2 focus:ring-[hsl(217,91%,50%)]/30" %>
    </div>

    <div class="space-y-1.5">
      <%= f.label :password_confirmation, "Confirmar contraseña",
          class: "block text-sm font-medium text-[hsl(222,47%,10%)]" %>
      <%= password_field_with_toggle f, :password_confirmation,
          autocomplete: "new-password",
          placeholder: "••••••••",
          class: "h-11 w-full rounded-lg border border-[hsl(215,20%,88%)] bg-white text-sm text-[hsl(222,47%,10%)] placeholder-[hsl(215,20%,65%)] transition focus:border-[hsl(217,91%,50%)] focus:outline-none focus:ring-2 focus:ring-[hsl(217,91%,50%)]/30" %>
    </div>

    <%= f.submit "Registrarse",
        class: "h-11 w-full cursor-pointer rounded-lg bg-[hsl(217,91%,50%)] text-sm font-medium text-white transition-colors hover:bg-[hsl(217,91%,45%)]" %>
  <% end %>
<% end %>
