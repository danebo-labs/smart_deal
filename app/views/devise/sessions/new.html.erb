<%= render layout: "devise/shared/auth_form_shell",
           locals: {
             title: "Iniciar sesión",
             subtitle: "Ingresa tus credenciales para acceder a la plataforma"
           } do %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name),
               html: { class: "space-y-5" }) do |f| %>

    <div class="space-y-1.5">
      <%= f.label :email, "Correo electrónico",
          class: "block text-sm font-medium text-[hsl(222,47%,10%)]" %>
      <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          placeholder: "tu@empresa.com",
          class: "h-11 w-full rounded-lg border border-[hsl(215,20%,88%)] bg-white px-3 text-sm text-[hsl(222,47%,10%)] placeholder-[hsl(215,20%,65%)] transition focus:border-[hsl(217,91%,50%)] focus:outline-none focus:ring-2 focus:ring-[hsl(217,91%,50%)]/30" %>
    </div>

    <div class="space-y-1.5">
      <div class="flex flex-col gap-1.5 sm:flex-row sm:items-center sm:justify-between sm:gap-2">
        <%= f.label :password, "Contraseña",
            class: "block text-sm font-medium text-[hsl(222,47%,10%)] sm:shrink-0" %>
        <%- if devise_mapping.recoverable? && controller_name != 'passwords' %>
          <%= link_to "¿Olvidaste tu contraseña?",
              new_password_path(resource_name),
              class: "text-xs leading-snug text-[hsl(215,20%,42%)] underline-offset-2 transition-colors hover:text-[hsl(222,47%,10%)] sm:text-right sm:leading-none sm:no-underline sm:hover:underline" %>
        <% end %>
      </div>
      <%= password_field_with_toggle f, :password,
          autocomplete: "current-password",
          placeholder: "••••••••",
          class: "h-11 w-full rounded-lg border border-[hsl(215,20%,88%)] bg-white text-sm text-[hsl(222,47%,10%)] placeholder-[hsl(215,20%,65%)] transition focus:border-[hsl(217,91%,50%)] focus:outline-none focus:ring-2 focus:ring-[hsl(217,91%,50%)]/30" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2.5">
        <%= f.check_box :remember_me,
            class: "h-4 w-4 cursor-pointer rounded border-[hsl(215,20%,88%)] text-[hsl(217,91%,50%)] focus:ring-[hsl(217,91%,50%)]/30" %>
        <%= f.label :remember_me, "Mantener sesión iniciada",
            class: "cursor-pointer select-none text-sm text-[hsl(215,20%,42%)]" %>
      </div>
    <% end %>

    <%= f.submit "Continuar",
        class: "h-11 w-full cursor-pointer rounded-lg bg-[hsl(217,91%,50%)] text-sm font-medium text-white transition-colors hover:bg-[hsl(217,91%,45%)]" %>
  <% end %>
<% end %>
