<div class="min-h-screen flex">

  <%# ── Left panel — brand ── %>
  <div class="hidden lg:flex lg:w-1/2 xl:w-3/5 bg-[#0f1729] relative overflow-hidden flex-col justify-between p-12 xl:p-16">

    <%# Subtle grid pattern %>
    <div class="absolute inset-0 opacity-[0.03]"
         style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;">
    </div>

    <%# Orbital rings %>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none">
      <div class="w-[500px] h-[500px] rounded-full border border-white/5 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 animate-spin-slow"></div>
      <div class="w-[380px] h-[380px] rounded-full border border-white/10 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 animate-spin-slower"></div>
      <div class="w-[260px] h-[260px] rounded-full border border-white/5 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 animate-spin-slow"></div>
      <div class="w-[200px] h-[200px] rounded-full bg-gradient-to-br from-[#2d4a7c]/20 to-transparent blur-3xl absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <%# Logo (desktop split panel) %>
    <div class="relative z-10 flex items-center gap-3">
      <%= image_tag "logo_desktop2.jpg",
          alt: "danebo",
          class: "w-16 h-16 rounded-2xl object-contain shadow-lg ring-1 ring-white/10 shrink-0",
          width: 64,
          height: 64 %>
      <div class="flex flex-col">
        <span class="font-light text-2xl text-white tracking-tight leading-none">danebo</span>
        <span class="text-xs font-light tracking-widest uppercase text-white/60">.IA</span>
      </div>
    </div>

    <%# Hero copy %>
    <div class="relative z-10 max-w-md">
      <h1 class="text-3xl xl:text-4xl font-light text-white leading-tight mb-6">
        Convierte la información de tu empresa en decisiones y automatización
      </h1>
      <div class="space-y-4 text-white/60 text-base leading-relaxed">
        <p>
          Las empresas tienen grandes volúmenes de información, pero no conocimiento accionable.
        </p>
        <p>
          Danebo transforma documentación interna, procesos y datos en conocimiento útil, integrado directamente en los flujos de trabajo.
        </p>
      </div>
      <p class="mt-5 text-sm text-white/50 leading-relaxed">
        No es solo análisis. Es ejecución. IA que automatiza tareas y mejora cómo trabajan tus equipos.
      </p>
    </div>

    <%# Footer badges %>
    <div class="relative z-10 flex items-center gap-6 text-sm text-white/40">
      <span>Seguro</span>
      <span class="w-1 h-1 rounded-full bg-white/20"></span>
      <span>Escalable</span>
      <span class="w-1 h-1 rounded-full bg-white/20"></span>
      <span>Empresarial</span>
    </div>
  </div>

  <%# ── Right panel — form ── %>
  <div class="flex-1 flex items-center justify-center p-6 sm:p-12 bg-[hsl(220,20%,97%)]">
    <div class="w-full max-w-sm">

      <%# Mobile logo %>
      <div class="lg:hidden mb-10 flex justify-center">
        <div class="flex items-center gap-3">
          <%= image_tag "logo_mobile.png",
              alt: "danebo",
              class: "w-14 h-14 rounded-2xl object-contain shadow-md ring-1 ring-[hsl(215,20%,88%)] shrink-0",
              width: 56,
              height: 56 %>
          <div class="flex flex-col">
            <span class="font-light text-2xl text-[hsl(222,47%,10%)] tracking-tight leading-none">danebo</span>
            <span class="text-xs font-light tracking-widest uppercase text-[hsl(215,20%,42%)]">.ai</span>
          </div>
        </div>
      </div>

      <%# Form header %>
      <div class="mb-8">
        <h2 class="text-2xl font-light text-[hsl(222,47%,10%)] mb-1.5">Iniciar sesión</h2>
        <p class="text-sm text-[hsl(215,20%,42%)]">Ingresa tus credenciales para acceder a la plataforma</p>
      </div>

      <%# Devise error block %>
      <% if resource.errors.any? %>
        <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-xs font-semibold text-red-700 mb-1"><%= pluralize(resource.errors.count, "error") %> al iniciar sesión:</p>
          <ul class="list-disc list-inside space-y-0.5">
            <% resource.errors.full_messages.each do |msg| %>
              <li class="text-xs text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Login form %>
      <%= form_for(resource, as: resource_name, url: session_path(resource_name),
                   html: { class: "space-y-5" }) do |f| %>

        <div class="space-y-1.5">
          <%= f.label :email, "Correo electrónico",
              class: "block text-sm font-medium text-[hsl(222,47%,10%)]" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "tu@empresa.com",
              class: "w-full h-11 px-3 text-sm bg-white border border-[hsl(215,20%,88%)] rounded-lg text-[hsl(222,47%,10%)] placeholder-[hsl(215,20%,65%)] focus:outline-none focus:ring-2 focus:ring-[hsl(217,91%,50%)]/30 focus:border-[hsl(217,91%,50%)] transition" %>
        </div>

        <div class="space-y-1.5">
          <div class="flex items-center justify-between">
            <%= f.label :password, "Contraseña",
                class: "block text-sm font-medium text-[hsl(222,47%,10%)]" %>
            <%- if devise_mapping.recoverable? && controller_name != 'passwords' %>
              <%= link_to "¿Olvidaste tu contraseña?",
                  new_password_path(resource_name),
                  class: "text-xs text-[hsl(215,20%,42%)] hover:text-[hsl(222,47%,10%)] transition-colors" %>
            <% end %>
          </div>
          <%= password_field_with_toggle f, :password,
              autocomplete: "current-password",
              placeholder: "••••••••",
              class: "w-full h-11 text-sm bg-white border border-[hsl(215,20%,88%)] rounded-lg text-[hsl(222,47%,10%)] placeholder-[hsl(215,20%,65%)] focus:outline-none focus:ring-2 focus:ring-[hsl(217,91%,50%)]/30 focus:border-[hsl(217,91%,50%)] transition" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2.5">
            <%= f.check_box :remember_me,
                class: "w-4 h-4 rounded border-[hsl(215,20%,88%)] text-[hsl(217,91%,50%)] focus:ring-[hsl(217,91%,50%)]/30 cursor-pointer" %>
            <%= f.label :remember_me, "Mantener sesión iniciada",
                class: "text-sm text-[hsl(215,20%,42%)] cursor-pointer select-none" %>
          </div>
        <% end %>

        <%= f.submit "Continuar",
            class: "w-full h-11 bg-[hsl(217,91%,50%)] hover:bg-[hsl(217,91%,45%)] text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>

      <% end %>

      <%# Bottom links (registerable, confirmable, lockable, etc.) %>
      <div class="mt-8 pt-6 border-t border-[hsl(215,20%,88%)]">
        <%= render "devise/shared/links" %>
      </div>

      <%# Footer %>
      <div class="mt-8">
        <p class="text-xs text-center text-[hsl(215,20%,60%)]">
          Al continuar, aceptas nuestros
          <a href="#" class="underline hover:text-[hsl(215,20%,42%)] transition-colors">Términos de Servicio</a>
          y
          <a href="#" class="underline hover:text-[hsl(215,20%,42%)] transition-colors">Política de Privacidad</a>
        </p>
      </div>

    </div>
  </div>

</div>
