<%# Logo — center on small viewports %>
<div class="mb-8 flex justify-center sm:mb-10 lg:hidden">
  <div class="flex items-center gap-3">
    <%= image_tag account_branding.logo_path,
        alt: account_branding.logo_alt,
        class: account_branding.branded? ? "h-14 w-auto max-w-[11rem] shrink-0 object-contain" : "h-14 w-14 shrink-0 rounded-2xl object-contain shadow-md ring-1 ring-[hsl(215,20%,88%)]",
        **(account_branding.branded? ? { height: 56 } : { width: 56, height: 56 }) %>
    <% if account_branding.show_danebo_wordmark? %>
      <div class="flex flex-col">
        <span class="text-2xl font-light leading-none tracking-tight text-[hsl(222,47%,10%)]">danebo</span>
        <span class="text-xs font-light uppercase tracking-widest text-[hsl(215,20%,42%)]">.ai</span>
      </div>
    <% end %>
  </div>
</div>
