<div class="flex flex-col items-center gap-2 text-sm">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Iniciar sesión",
        new_session_path(resource_name),
        class: "text-[hsl(217,91%,50%)] hover:text-[hsl(217,91%,40%)] font-medium transition-colors" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p class="text-[hsl(215,20%,42%)]">
      ¿No tienes una cuenta?
      <%= link_to "Solicita acceso",
          new_registration_path(resource_name),
          class: "text-[hsl(217,91%,50%)] hover:text-[hsl(217,91%,40%)] font-medium transition-colors" %>
    </p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "¿No recibiste el correo de confirmación?",
        new_confirmation_path(resource_name),
        class: "text-[hsl(215,20%,42%)] hover:text-[hsl(222,47%,10%)] transition-colors" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "¿No recibiste las instrucciones de desbloqueo?",
        new_unlock_path(resource_name),
        class: "text-[hsl(215,20%,42%)] hover:text-[hsl(222,47%,10%)] transition-colors" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Iniciar sesión con #{OmniAuth::Utils.camelize(provider)}",
          omniauth_authorize_path(resource_name, provider),
          data: { turbo: false },
          class: "text-[hsl(215,20%,42%)] hover:text-[hsl(222,47%,10%)] transition-colors" %>
    <% end %>
  <% end %>
</div>
