<%# Chat section — spans 2 columns on lg screens %>
<div class="lg:col-span-2">
  <%#
    Mobile:  static height = 100svh - 58px (small viewport height, does NOT shrink with
             the on-screen keyboard). The KB list and chat panes therefore stay frozen
             behind the keyboard. The textarea stack alone is lifted above the keyboard
             via the VisualViewport API (see rag_chat_controller#setupKeyboardLift).
    Desktop: viewport minus nav + page header + page padding.
  %>
  <div class="relative flex h-[calc(100svh-58px)] md:h-[calc(100vh-220px)] md:min-h-[600px] flex-col overflow-hidden
              rounded-none md:rounded-2xl border-0 md:border border-[hsl(215,20%,88%)] bg-white md:shadow-sm">

    <%# Chat header — desktop only %>
    <div class="hidden md:flex items-center gap-3 border-b border-[hsl(215,20%,90%)] px-6 py-4 flex-shrink-0">
      <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[hsl(217,91%,50%,0.08)] flex-shrink-0">
        <svg class="h-5 w-5 text-[hsl(217,91%,50%)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 15c0 .53-.21 1.04-.59 1.41-.37.38-.88.59-1.41.59H7l-4 4V5c0-.53.21-1.04.59-1.41C3.96 3.21 4.47 3 5 3h14c.53 0 1.04.21 1.41.59.38.37.59.88.59 1.41v10z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-[hsl(222,47%,10%)]">Consulta los archivos disponibles en la base de conocimiento</p>
      </div>
    </div>

    <%# Content area: flex column, takes all remaining height %>
    <div class="flex-1 flex flex-col min-h-0 overflow-hidden">

      <%# ── MOBILE: KB documents panel ──
           Height managed by JS (updateMobileLayout) so the user can always
           reach every KB document (including the most recent one at the top):
           • empty chat  → flex: 1 1 0%                  (fills the viewport)
           • active chat → flex: 0 0 calc(50svh - 58px)  (KB ≥ 50% of viewport,
                                                          chat ≤ 50% incl. textarea)
      %>
      <div class="mobile-docs-panel md:hidden border-b border-[hsl(215,20%,90%)] overflow-y-auto overscroll-contain min-h-0">
        <%= render partial: "home/kb_docs_card",
                   locals: {
                     kb_documents: @kb_documents || KbDocument.none,
                     has_more:     @kb_docs_has_more || false,
                     variant:      :mobile,
                     next_page:    1
                   } %>
      </div>

      <%# ── Messages scroll area (mobile bottom 58 % + full desktop) ── %>
      <div class="flex-1 overflow-y-auto overscroll-contain px-4 md:px-6 py-4 bg-[hsl(220,20%,98%)]"
           data-rag-chat-target="chatContainer">
        <div class="flex flex-col gap-4" data-rag-chat-target="messages"></div>
      </div>

    </div><%# /content area %>

    <%# Input stack (file preview + textarea + buttons).
        On mobile this whole block gets translated up by --kbd-h (set by
        rag_chat_controller from the VisualViewport API) so the textarea
        sits anchored above the on-screen keyboard while the KB list and
        chat messages above it remain perfectly still. %>
    <div class="chat-input-stack flex flex-col bg-white" data-rag-chat-target="inputStack">

    <%# File preview %>
    <div class="chat-image-preview mx-3 md:mx-6 mb-2" data-rag-chat-target="filePreview" style="display:none;">
      <div class="flex items-center gap-2 rounded-lg bg-[hsl(215,20%,95%)] border border-[hsl(215,20%,88%)] px-3 py-2">
        <img data-rag-chat-target="imageThumb" class="max-h-12 max-w-12 rounded object-cover hidden" alt="">
        <svg data-rag-chat-target="docIcon" class="h-8 w-8 text-[hsl(215,20%,50%)] hidden flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
        <span data-rag-chat-target="fileName" class="flex-1 text-xs text-[hsl(215,20%,42%)] truncate"></span>
        <button type="button" data-action="click->rag-chat#removeFile"
                class="rounded-full p-1 hover:bg-[hsl(215,20%,88%)] text-[hsl(215,20%,50%)] hover:text-[hsl(222,47%,10%)] transition-colors"
                aria-label="Quitar archivo">
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <%# Input area %>
    <div class="border-t border-[hsl(215,20%,90%)] p-3 md:p-4 bg-white flex-shrink-0">
      <form class="chat-composer-form" data-action="submit->rag-chat#sendMessage">
        <input type="file"
               data-rag-chat-target="fileInput"
               data-action="change->rag-chat#selectFile"
               accept="image/png,image/jpeg,image/gif,image/webp,.txt,.md,.html,.csv,.pdf,.doc,.docx,.xls,.xlsx"
               class="hidden">

        <%# Textarea wrapper — full width, bordered %>
        <div class="flex items-center gap-2 rounded-xl border border-[hsl(215,20%,86%)] bg-[hsl(220,20%,98%)] px-3 py-2 mb-3 focus-within:border-[hsl(217,91%,50%)] focus-within:ring-1 focus-within:ring-[hsl(217,91%,50%,0.2)]">
          <%# Attach button inside box — desktop only %>
          <button type="button"
                  data-action="click->rag-chat#clickAttach"
                  class="hidden sm:flex shrink-0 rounded-lg p-2 text-[hsl(215,20%,50%)] hover:bg-[hsl(215,20%,92%)] hover:text-[hsl(222,47%,10%)] transition-colors"
                  title="Adjuntar imagen o documento" aria-label="Adjuntar archivo">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/>
            </svg>
          </button>
          <textarea
            class="min-h-[40px] max-h-[120px] flex-1 resize-none bg-transparent text-sm text-[hsl(222,47%,10%)] placeholder:text-[hsl(215,20%,62%)] focus:outline-none"
            data-rag-chat-target="input"
            data-action="keydown->rag-chat#handleKeyPress"
            placeholder="Escribe tu pregunta aquí..."
            rows="1"></textarea>
        </div>

        <%# Action row: attach (mobile-only, left) ↔ send (right) %>
        <div class="flex items-center justify-between sm:justify-end gap-2">
          <%# Attach — icon button, mobile only %>
          <button type="button"
                  data-action="click->rag-chat#clickAttach"
                  class="sm:hidden flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[hsl(215,20%,86%)] bg-[hsl(220,20%,98%)] text-[hsl(215,20%,50%)] hover:bg-[hsl(215,20%,92%)] hover:text-[hsl(222,47%,10%)] transition-colors"
                  title="Adjuntar imagen o documento" aria-label="Adjuntar archivo">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/>
            </svg>
          </button>

          <%# Send — icon only on mobile, icon + "Enviar" on desktop %>
          <button type="submit"
                  class="flex shrink-0 h-10 items-center justify-center gap-2 rounded-xl bg-[hsl(217,91%,50%)] hover:bg-[hsl(217,91%,44%)] text-white font-medium px-4 sm:px-5 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                  data-rag-chat-target="sendButton">
            <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
            </svg>
            <span class="hidden sm:inline">Enviar</span>
          </button>
        </div>

        <p class="mt-2 text-center text-[10px] text-[hsl(215,20%,58%)] hidden md:block">
          Imágenes máx. 3.75 MB (JPEG/PNG) · Documentos máx. 50 MB
        </p>
      </form>
    </div>

    </div><%# /chat-input-stack %>

    <%# Footer metrics — hidden on mobile %>
    <div class="hidden sm:flex items-center justify-end gap-6 border-t border-[hsl(215,20%,90%)] bg-[hsl(220,20%,98%)] px-6 py-3 flex-shrink-0">
      <div id="chat-usage-metrics-container">
        <%= render partial: "home/chat_usage_footer_metrics", locals: { current_metrics: @current_metrics } %>
      </div>
    </div>

  </div>
</div>
