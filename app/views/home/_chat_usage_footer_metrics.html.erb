<%# Tokens + cost — targeted by Turbo Stream updates %>
<div class="flex items-center gap-6" data-chat-usage-metrics="true">
  <div class="flex items-baseline gap-2" data-metric-type="tokens">
    <span class="text-[10px] font-semibold tracking-wider text-[hsl(215,20%,52%)] uppercase">Tokens</span>
    <span class="font-mono text-sm font-semibold text-[hsl(222,47%,10%)] tabular-nums" data-metric-value="tokens">
      <%= number_with_delimiter(current_metrics[:today_tokens]) %>
    </span>
  </div>
  <div class="flex items-baseline gap-2" data-metric-type="cost">
    <span class="text-[10px] font-semibold tracking-wider text-[hsl(215,20%,52%)] uppercase">Costo hoy</span>
    <span class="font-mono text-sm font-semibold tabular-nums text-red-500" data-metric-value="cost">
      $<%= current_metrics[:today_cost].round(4) %>
    </span>
  </div>
</div>
