<div class="knowledge-base-content">
  <% if documents.any? %>
    <div class="documents-list">
      <% documents.each_with_index do |doc, index| %>
        <div class="document-item-card">
          <div class="document-item-header">
            <span class="document-number">[<%= index + 1 %>]</span>
            <span class="document-name-primary" title="<%= doc[:name] %>"><%= doc[:name] %></span>
            <% case doc[:status] %>
            <% when :indexing %>
              <span class="document-status document-status-indexing" title="Indexando">
                <svg class="document-spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/>
                  <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                </svg>
              </span>
            <% when :failed %>
              <span class="document-status document-status-failed" title="Error al indexar">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2.5"/>
                  <line x1="15" y1="9" x2="9" y2="15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="9" y1="9" x2="15" y2="15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
              </span>
            <% else %>
              <span class="document-status document-status-indexed" title="Indexado">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            <% end %>
          </div>
          <% if doc[:updated_at] %>
            <div class="document-meta-secondary">
              <%= format_document_date(doc[:updated_at]) %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="documents-summary">
      <div class="summary-item">
        <span class="summary-label">Total Documents:</span>
        <span class="summary-value"><%= documents.count { |d| d[:status] == :indexed } %></span>
      </div>
    </div>
  <% else %>
    <div class="document-info-placeholder">
      <svg width="80" height="80" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="document-placeholder-icon">
        <path d="M14 2H6C5.46957 2 4.96086 2.21071 4.58579 2.58579C4.21071 2.96086 4 3.46957 4 4V20C4 20.5304 4.21071 21.0391 4.58579 21.4142C4.96086 21.7893 5.46957 22 6 22H18C18.5304 22 19.0391 21.7893 19.4142 21.4142C19.7893 21.0391 20 20.5304 20 20V8L14 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <path d="M14 2V8H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
      <p class="document-placeholder-text">No documents in Knowledge Base</p>
    </div>
  <% end %>
</div>
