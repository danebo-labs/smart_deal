<% kb_documents = kb_documents.to_a %>
<% if kb_documents.any? %>
  <div class="space-y-1">
    <% kb_documents.each_with_index do |doc, index| %>
      <% title = doc.display_name.presence || doc.s3_key.to_s %>
      <% aliases_line = doc.simplest_display_aliases(2) %>
      <div class="group flex items-start gap-3 rounded-lg px-3 py-2.5 hover:bg-[hsl(215,20%,95%)] transition-colors">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded bg-[hsl(215,20%,92%)] text-xs font-medium text-[hsl(215,20%,42%)]">
          <%= index + 1 %>
        </span>
        <div class="min-w-0 flex-1">
          <p class="truncate text-sm font-medium text-[hsl(222,47%,10%)]" title="<%= title %>"><%= title %></p>
          <% if aliases_line.any? %>
            <div class="mt-1 hidden sm:flex flex-wrap gap-1">
              <% aliases_line.each do |alias_text| %>
                <span class="rounded bg-[hsl(217,91%,96%)] border border-[hsl(217,91%,88%)] px-1.5 py-0.5 text-[10px] text-[hsl(217,91%,40%)]" title="<%= alias_text %>">
                  <%= alias_text %>
                </span>
              <% end %>
            </div>
          <% end %>
          <p class="text-xs text-[hsl(215,20%,55%)]"><%= l(doc.created_at, format: :short) %></p>
        </div>
        <svg class="h-4 w-4 shrink-0 text-[hsl(215,20%,62%)] opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/>
        </svg>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center py-8 gap-3">
    <svg class="h-12 w-12 text-[hsl(215,20%,75%)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
    </svg>
    <p class="text-sm text-[hsl(215,20%,55%)]">Sin archivos</p>
  </div>
<% end %>
