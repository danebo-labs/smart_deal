<%#
  Shared KB documents card. Renders identically (rows + checkbox + thumbnail) on
  desktop and mobile. variant only changes the outer wrapper:
    :mobile  → in-chat scrollable flex panel (md:hidden)
    :desktop → rounded card with header (hidden lg:flex sidebar slot)
%>
<% items_id    = "kb-docs-#{variant}-items" %>
<% sentinel_id = "kb-docs-#{variant}-sentinel" %>

<% if variant == :desktop %>
  <div class="flex-1 rounded-2xl border border-[hsl(215,20%,88%)] bg-white p-5 shadow-sm">
    <div class="mb-4 flex items-center gap-2">
      <svg class="h-4 w-4 text-[hsl(217,91%,50%)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="9" y1="13" x2="15" y2="13"/>
        <line x1="9" y1="17" x2="15" y2="17"/>
        <polyline points="9 9 10 9 11 9"/>
      </svg>
      <h3 class="text-sm font-medium text-[hsl(222,47%,10%)]">Base de Conocimiento</h3>
    </div>
    <div class="overflow-y-auto max-h-[calc(100vh-300px)] pr-1">
<% end %>

<div id="<%= items_id %>" class="<%= variant == :mobile ? 'space-y-1.5 p-3' : 'space-y-1.5' %>">
  <% if kb_documents.any? %>
    <%= render partial: "home/kb_docs_card_rows", locals: { kb_documents: kb_documents } %>
  <% else %>
    <div class="flex flex-col items-center justify-center gap-3 py-8">
      <svg class="h-10 w-10 text-[hsl(215,20%,75%)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
      <p class="text-sm text-[hsl(215,20%,55%)]">Sin documentos en la base de conocimiento</p>
    </div>
  <% end %>
</div>

<% if has_more %>
  <%= render partial: "home/kb_docs_card_sentinel",
             locals: { sentinel_id: sentinel_id, page: next_page } %>
<% end %>

<% if variant == :desktop %>
    </div>
  </div>
<% end %>
