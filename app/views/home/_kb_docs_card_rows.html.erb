<% kb_documents.each do |doc| %>
  <% doc_ext     = File.extname(doc.s3_key.to_s).downcase %>
  <% doc_is_image = %w[.png .jpg .jpeg].include?(doc_ext) %>
  <% aliases_list = doc.simplest_display_aliases(1) %>
  <% title        = doc.display_name.presence || aliases_list.first.presence || doc.s3_key.to_s %>
  <button type="button"
          data-action="click->rag-chat#toggleDocSelection"
          data-doc-name="<%= title %>"
          data-selected="false"
          class="kb-doc-btn group flex w-full items-center gap-3 rounded-xl px-3 py-2.5 text-left border-2 border-transparent bg-[hsl(215,20%,96%)] transition-all duration-200 active:scale-[0.98]">
    <%# Thumbnail — real JPEG when indexed, SVG fallback otherwise %>
    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[hsl(215,20%,90%)] overflow-hidden">
      <% if doc_is_image && doc.thumbnail %>
        <img src="<%= doc.thumbnail.data_url %>"
             class="h-full w-full object-cover"
             alt=""
             loading="lazy">
      <% elsif doc_is_image %>
        <svg class="h-5 w-5 text-[hsl(215,20%,52%)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
          <circle cx="9" cy="9" r="2"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
        </svg>
      <% else %>
        <svg class="h-5 w-5 text-[hsl(215,20%,52%)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="9" y1="13" x2="15" y2="13"/>
          <line x1="9" y1="17" x2="15" y2="17"/>
        </svg>
      <% end %>
    </div>
    <div class="min-w-0 flex-1">
      <p class="truncate text-sm font-medium text-[hsl(222,47%,10%)]"><%= title %></p>
      <p class="truncate text-[11px] text-[hsl(215,20%,52%)] mt-0.5"><%= l(doc.created_at, format: :short) %></p>
    </div>
    <span class="kb-doc-checkbox flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-[hsl(215,20%,88%)] transition-all"></span>
  </button>
<% end %>
