<% kb_documents.each do |doc| %>
  <% doc_ext      = File.extname(doc.s3_key.to_s).downcase %>
  <% doc_is_image = %w[.png .jpg .jpeg .webp .gif].include?(doc_ext) %>
  <% aliases_list = doc.simplest_display_aliases(1) %>
  <% title        = doc.display_name.presence || aliases_list.first.presence || doc.s3_key.to_s %>
  <% is_pinned    = pinned_uris.include?(doc.display_s3_uri(KbDocument::KB_BUCKET)) %>
  <% full_url     = doc_is_image ? image_url_service&.call(doc) : nil %>
  <% has_lightbox = doc_is_image && doc.thumbnail.present? && full_url.present? %>

  <div role="button"
       tabindex="0"
       data-action="click->rag-chat#toggleDocSelection keydown.enter->rag-chat#toggleDocSelection keydown.space->rag-chat#toggleDocSelection"
       data-doc-id="<%= doc.id %>"
       data-doc-name="<%= title %>"
       data-selected="<%= is_pinned %>"
       class="kb-doc-btn group flex w-full items-center gap-3 rounded-xl px-3 py-2.5 text-left border-2 cursor-pointer <%= is_pinned ? 'border-[hsl(217,91%,50%)] bg-[hsl(217,91%,50%,0.06)]' : 'border-transparent bg-[hsl(215,20%,96%)]' %> transition-all duration-200 active:scale-[0.98]">

    <%# Thumbnail — clickable when image+thumb+url available, otherwise plain %>
    <% if has_lightbox %>
      <button type="button"
              data-controller="image-lightbox"
              data-action="click->image-lightbox#open:stop keydown.enter->image-lightbox#open:stop keydown.space->image-lightbox#open:stop"
              data-image-lightbox-full-url-value="<%= full_url %>"
              data-image-lightbox-thumb-url-value="<%= doc.thumbnail.data_url %>"
              data-image-lightbox-name-value="<%= title %>"
              aria-label="<%= t('home.lightbox.open_aria', name: title) %>"
              class="kb-doc-thumb-btn flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[hsl(215,20%,90%)] overflow-hidden ring-0 hover:ring-2 hover:ring-[hsl(217,91%,50%,0.4)] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[hsl(217,91%,50%)]">
        <img src="<%= doc.thumbnail.data_url %>"
             class="h-full w-full object-cover pointer-events-none"
             alt=""
             loading="lazy">
      </button>
    <% else %>
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[hsl(215,20%,90%)] overflow-hidden">
        <% if doc_is_image && doc.thumbnail %>
          <img src="<%= doc.thumbnail.data_url %>"
               class="h-full w-full object-cover"
               alt=""
               loading="lazy">
        <% elsif doc_is_image %>
          <svg class="h-5 w-5 text-[hsl(215,20%,52%)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
            <circle cx="9" cy="9" r="2"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
        <% else %>
          <svg class="h-5 w-5 text-[hsl(215,20%,52%)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="9" y1="13" x2="15" y2="13"/>
            <line x1="9" y1="17" x2="15" y2="17"/>
          </svg>
        <% end %>
      </div>
    <% end %>

    <div class="min-w-0 flex-1">
      <p class="truncate text-sm font-medium text-[hsl(222,47%,10%)]"><%= title %></p>
      <p class="truncate text-[11px] text-[hsl(215,20%,52%)] mt-0.5"><%= l(doc.created_at, format: :short) %></p>
    </div>
    <span class="kb-doc-checkbox flex h-6 w-6 shrink-0 items-center justify-center rounded-md <%= is_pinned ? 'bg-[hsl(217,91%,50%)] text-white' : 'bg-[hsl(215,20%,88%)]' %> transition-all">
      <% if is_pinned %>
        <svg style="width:14px;height:14px;display:block;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      <% end %>
    </span>
  </div>
<% end %>
