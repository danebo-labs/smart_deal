<nav aria-label="<%= t("auth.locale.label") %>" class="inline-flex items-center gap-1 rounded-lg border border-[hsl(215,20%,88%)] bg-white p-0.5 text-xs font-medium">
  <% LocaleSwitchable::ALLOWED_LOCALES.each do |locale| %>
    <% if locale == I18n.locale %>
      <span class="rounded-md bg-[hsl(217,91%,50%)] px-2.5 py-1 text-white"
            aria-current="true"><%= t("auth.locale.#{locale}") %></span>
    <% else %>
      <%= link_to t("auth.locale.#{locale}"),
          switch_locale_path(locale),
          class: "rounded-md px-2.5 py-1 text-[hsl(215,20%,42%)] transition-colors hover:bg-[hsl(215,20%,93%)] hover:text-[hsl(222,47%,10%)]" %>
    <% end %>
  <% end %>
</nav>
